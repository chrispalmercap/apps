<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Flourish — Habit & Life Goals</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0d0f14;
  --surface: #13161e;
  --surface2: #1a1e2a;
  --surface3: #222736;
  --border: rgba(255,255,255,0.07);
  --text: #f0f2f7;
  --muted: #6b7280;
  --accent: #c8a97e;
  --accent2: #7eb8c8;

  --physical: #f97316;
  --biological: #22c55e;
  --social: #a78bfa;
  --emotional: #f472b6;
  --spiritual: #facc15;

  --sidebar-w: 220px;
  --radius: 16px;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  display: flex;
  overflow: hidden;
}

/* ─── SIDEBAR ─────────────────────────────────────────────── */
.sidebar {
  width: var(--sidebar-w);
  min-height: 100vh;
  background: var(--surface);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  padding: 28px 0;
  flex-shrink: 0;
  position: relative;
  z-index: 10;
}

.sidebar-logo {
  padding: 0 20px 28px;
  border-bottom: 1px solid var(--border);
}

.logo-mark {
  font-family: 'Playfair Display', serif;
  font-size: 22px;
  font-weight: 900;
  color: var(--accent);
  letter-spacing: -0.5px;
}

.logo-sub {
  font-size: 10px;
  color: var(--muted);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-top: 2px;
}

.new-goal-btn {
  margin: 18px 14px;
  padding: 11px 14px;
  background: var(--accent);
  color: #0d0f14;
  border: none;
  border-radius: 10px;
  font-family: 'DM Sans', sans-serif;
  font-weight: 600;
  font-size: 13px;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 8px;
  transition: opacity 0.2s, transform 0.15s;
}
.new-goal-btn:hover { opacity: 0.88; transform: translateY(-1px); }
.new-goal-btn svg { width: 15px; height: 15px; }

.sidebar-section-label {
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--muted);
  padding: 10px 20px 6px;
}

.cat-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 20px;
  cursor: pointer;
  border-radius: 0;
  transition: background 0.15s;
  position: relative;
  font-size: 13.5px;
  font-weight: 500;
  color: var(--muted);
}
.cat-item:hover { background: var(--surface2); color: var(--text); }
.cat-item.active { background: var(--surface2); color: var(--text); }
.cat-item.active::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 3px;
  border-radius: 0 2px 2px 0;
}
.cat-item[data-cat="all"].active::before { background: var(--accent); }
.cat-item[data-cat="physical"].active::before { background: var(--physical); }
.cat-item[data-cat="biological"].active::before { background: var(--biological); }
.cat-item[data-cat="social"].active::before { background: var(--social); }
.cat-item[data-cat="emotional"].active::before { background: var(--emotional); }
.cat-item[data-cat="spiritual"].active::before { background: var(--spiritual); }

.cat-icon {
  width: 28px; height: 28px;
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 15px;
  flex-shrink: 0;
}
.cat-item[data-cat="all"] .cat-icon { background: rgba(200,169,126,0.15); }
.cat-item[data-cat="physical"] .cat-icon { background: rgba(249,115,22,0.15); }
.cat-item[data-cat="biological"] .cat-icon { background: rgba(34,197,94,0.15); }
.cat-item[data-cat="social"] .cat-icon { background: rgba(167,139,250,0.15); }
.cat-item[data-cat="emotional"] .cat-icon { background: rgba(244,114,182,0.15); }
.cat-item[data-cat="spiritual"] .cat-icon { background: rgba(250,204,21,0.15); }

.cat-badge {
  margin-left: auto;
  background: var(--surface3);
  color: var(--muted);
  font-size: 10px;
  font-weight: 600;
  border-radius: 20px;
  padding: 2px 7px;
  min-width: 20px;
  text-align: center;
}

.sidebar-bottom {
  margin-top: auto;
  padding: 16px 14px 0;
  border-top: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.sidebar-nav-btn {
  display: flex;
  align-items: center;
  gap: 9px;
  padding: 9px 12px;
  border-radius: 9px;
  cursor: pointer;
  font-size: 13px;
  color: var(--muted);
  transition: background 0.15s, color 0.15s;
  border: none;
  background: none;
  width: 100%;
  font-family: 'DM Sans', sans-serif;
  font-weight: 500;
}
.sidebar-nav-btn:hover { background: var(--surface2); color: var(--text); }
.sidebar-nav-btn.active { background: var(--surface2); color: var(--text); }

/* ─── MAIN ─────────────────────────────────────────────────── */
.main {
  flex: 1;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
}

.topbar {
  padding: 24px 32px 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
}

.topbar-greeting {
  font-family: 'Playfair Display', serif;
  font-size: 26px;
  font-weight: 700;
  letter-spacing: -0.5px;
}

.topbar-date {
  font-size: 12px;
  color: var(--muted);
  margin-top: 3px;
}

.topbar-right {
  display: flex;
  align-items: center;
  gap: 10px;
}

.icon-btn {
  width: 38px; height: 38px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  transition: background 0.15s, border-color 0.15s;
  position: relative;
}
.icon-btn:hover { background: var(--surface2); border-color: rgba(255,255,255,0.14); }
.icon-btn svg { width: 18px; height: 18px; color: var(--muted); }

.notif-dot {
  position: absolute;
  top: 6px; right: 6px;
  width: 7px; height: 7px;
  background: var(--accent);
  border-radius: 50%;
  border: 2px solid var(--bg);
}

.content-area {
  padding: 24px 32px 40px;
  flex: 1;
}

/* ─── DAILY CHECK-IN BANNER ───────────────────────────────── */
.checkin-banner {
  background: linear-gradient(135deg, rgba(200,169,126,0.12), rgba(126,184,200,0.08));
  border: 1px solid rgba(200,169,126,0.25);
  border-radius: var(--radius);
  padding: 18px 22px;
  margin-bottom: 26px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}

.checkin-left { flex: 1; }
.checkin-label {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--accent);
  margin-bottom: 4px;
}
.checkin-text {
  font-size: 15px;
  font-weight: 500;
  color: var(--text);
}
.checkin-sub {
  font-size: 12px;
  color: var(--muted);
  margin-top: 2px;
}

.checkin-btn {
  background: var(--accent);
  color: #0d0f14;
  border: none;
  border-radius: 10px;
  padding: 10px 18px;
  font-family: 'DM Sans', sans-serif;
  font-weight: 600;
  font-size: 13px;
  cursor: pointer;
  white-space: nowrap;
  transition: opacity 0.2s, transform 0.15s;
}
.checkin-btn:hover { opacity: 0.88; transform: translateY(-1px); }

/* ─── STATS ROW ─────────────────────────────────────────────── */
.stats-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  margin-bottom: 26px;
}

.stat-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px 18px;
}

.stat-label {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--muted);
  margin-bottom: 8px;
}

.stat-value {
  font-family: 'Playfair Display', serif;
  font-size: 28px;
  font-weight: 700;
  line-height: 1;
}

.stat-sub {
  font-size: 11px;
  color: var(--muted);
  margin-top: 4px;
}

/* ─── SECTION HEADER ─────────────────────────────────────────── */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14px;
}

.section-title {
  font-family: 'Playfair Display', serif;
  font-size: 18px;
  font-weight: 700;
}

.section-link {
  font-size: 12px;
  color: var(--accent);
  cursor: pointer;
  text-decoration: none;
  opacity: 0.8;
  transition: opacity 0.15s;
}
.section-link:hover { opacity: 1; }

/* ─── HABIT CARDS ─────────────────────────────────────────────── */
.habits-grid {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 30px;
}

.habit-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px 18px;
  display: flex;
  align-items: center;
  gap: 14px;
  transition: border-color 0.2s, background 0.2s;
  position: relative;
  overflow: hidden;
}

.habit-card::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 3px;
  border-radius: 0 2px 2px 0;
}
.habit-card[data-cat="physical"]::before { background: var(--physical); }
.habit-card[data-cat="biological"]::before { background: var(--biological); }
.habit-card[data-cat="social"]::before { background: var(--social); }
.habit-card[data-cat="emotional"]::before { background: var(--emotional); }
.habit-card[data-cat="spiritual"]::before { background: var(--spiritual); }

.habit-card.completed {
  background: var(--surface2);
  border-color: rgba(255,255,255,0.03);
}

.habit-card.completed .habit-name { text-decoration: line-through; opacity: 0.5; }
.habit-card.completed .habit-affirmation { opacity: 0.4; }
.habit-card.paused { opacity: 0.55; }

.complete-btn {
  width: 38px; height: 38px;
  border-radius: 50%;
  border: 2px solid var(--border);
  background: transparent;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}

.habit-card[data-cat="physical"] .complete-btn { border-color: rgba(249,115,22,0.4); }
.habit-card[data-cat="biological"] .complete-btn { border-color: rgba(34,197,94,0.4); }
.habit-card[data-cat="social"] .complete-btn { border-color: rgba(167,139,250,0.4); }
.habit-card[data-cat="emotional"] .complete-btn { border-color: rgba(244,114,182,0.4); }
.habit-card[data-cat="spiritual"] .complete-btn { border-color: rgba(250,204,21,0.4); }

.complete-btn:hover { transform: scale(1.1); }
.habit-card.completed .complete-btn {
  border-color: transparent;
}
.habit-card[data-cat="physical"].completed .complete-btn { background: var(--physical); }
.habit-card[data-cat="biological"].completed .complete-btn { background: var(--biological); }
.habit-card[data-cat="social"].completed .complete-btn { background: var(--social); }
.habit-card[data-cat="emotional"].completed .complete-btn { background: var(--emotional); }
.habit-card[data-cat="spiritual"].completed .complete-btn { background: var(--spiritual); }

.complete-btn .check-icon { display: none; width: 18px; height: 18px; }
.habit-card.completed .complete-btn .check-icon { display: block; }
.habit-card.completed .complete-btn .circle-icon { display: none; }

.habit-info { flex: 1; min-width: 0; }
.habit-name { font-size: 14.5px; font-weight: 600; margin-bottom: 2px; }
.habit-affirmation {
  font-size: 11.5px;
  color: var(--accent);
  font-style: italic;
  margin-bottom: 5px;
}
.habit-meta {
  display: flex;
  align-items: center;
  gap: 10px;
}
.habit-streak {
  font-size: 11px;
  color: var(--muted);
  display: flex;
  align-items: center;
  gap: 3px;
}
.habit-freq {
  font-size: 10px;
  background: var(--surface3);
  border-radius: 20px;
  padding: 2px 8px;
  color: var(--muted);
}

.habit-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6px;
  flex-shrink: 0;
}

.habit-dots {
  display: flex;
  gap: 4px;
}
.habit-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--surface3);
}
.habit-dot.done { background: var(--accent); }
.habit-card[data-cat="physical"] .habit-dot.done { background: var(--physical); }
.habit-card[data-cat="biological"] .habit-dot.done { background: var(--biological); }
.habit-card[data-cat="social"] .habit-dot.done { background: var(--social); }
.habit-card[data-cat="emotional"] .habit-dot.done { background: var(--emotional); }
.habit-card[data-cat="spiritual"] .habit-dot.done { background: var(--spiritual); }

.habit-actions {
  display: flex;
  gap: 5px;
  opacity: 0;
  transition: opacity 0.2s;
}
.habit-card:hover .habit-actions { opacity: 1; }

.hab-action-btn {
  background: var(--surface3);
  border: none;
  border-radius: 7px;
  width: 28px; height: 28px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  transition: background 0.15s;
}
.hab-action-btn:hover { background: var(--surface2); }
.hab-action-btn svg { width: 13px; height: 13px; color: var(--muted); }

.paused-badge {
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 1px;
  background: rgba(107,114,128,0.2);
  color: var(--muted);
  border-radius: 20px;
  padding: 3px 8px;
}

/* ─── INSIGHTS ─────────────────────────────────────────────── */
.insights-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-bottom: 30px;
}

.insight-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 18px 20px;
}

.insight-title {
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--muted);
  margin-bottom: 14px;
}

.focus-bars { display: flex; flex-direction: column; gap: 8px; }
.focus-bar-row { display: flex; align-items: center; gap: 10px; }
.focus-bar-label { font-size: 12px; width: 80px; color: var(--muted); }
.focus-bar-track {
  flex: 1;
  height: 6px;
  background: var(--surface3);
  border-radius: 3px;
  overflow: hidden;
}
.focus-bar-fill {
  height: 100%;
  border-radius: 3px;
  transition: width 0.6s ease;
}
.focus-bar-pct { font-size: 11px; color: var(--muted); width: 28px; text-align: right; }

.tip-card {
  background: linear-gradient(135deg, rgba(126,184,200,0.08), rgba(200,169,126,0.05));
  border: 1px solid rgba(126,184,200,0.15);
  border-radius: 10px;
  padding: 14px 16px;
  margin-top: 12px;
}
.tip-label { font-size: 9px; text-transform: uppercase; letter-spacing: 2px; color: var(--accent2); margin-bottom: 5px; }
.tip-text { font-size: 12.5px; color: var(--text); line-height: 1.5; }

/* ─── CALENDAR ─────────────────────────────────────────────── */
.calendar-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 18px 20px;
  margin-bottom: 30px;
}

.cal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14px;
}

.cal-nav {
  display: flex;
  gap: 6px;
}

.cal-nav-btn {
  background: var(--surface3);
  border: none;
  border-radius: 7px;
  width: 28px; height: 28px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  color: var(--muted);
  transition: background 0.15s;
}
.cal-nav-btn:hover { background: var(--surface2); color: var(--text); }
.cal-nav-btn svg { width: 14px; height: 14px; }

.cal-month { font-size: 14px; font-weight: 600; }

.cal-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4px;
}

.cal-day-label {
  text-align: center;
  font-size: 10px;
  color: var(--muted);
  letter-spacing: 1px;
  padding-bottom: 6px;
}

.cal-day {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  font-size: 12px;
  cursor: pointer;
  position: relative;
  transition: background 0.15s;
  color: var(--muted);
}
.cal-day:hover { background: var(--surface3); }
.cal-day.in-month { color: var(--text); }
.cal-day.today {
  background: var(--surface3);
  color: var(--accent);
  font-weight: 700;
}
.cal-day.completed { background: rgba(200,169,126,0.15); color: var(--accent); }
.cal-day.perfect {
  background: var(--accent);
  color: #0d0f14;
  font-weight: 700;
}
.cal-day::after {
  content: '';
  position: absolute;
  bottom: 4px;
  width: 4px; height: 4px;
  border-radius: 50%;
  background: var(--accent);
  display: none;
}
.cal-day.has-dot::after { display: block; }

/* ─── SPONSOR ─────────────────────────────────────────────── */
.sponsor-card {
  background: linear-gradient(135deg, rgba(167,139,250,0.08), rgba(200,169,126,0.06));
  border: 1px solid rgba(167,139,250,0.2);
  border-radius: var(--radius);
  padding: 18px 20px;
  margin-bottom: 30px;
}

.sponsor-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.sponsor-label {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--social);
}

.sponsor-add-btn {
  background: rgba(167,139,250,0.15);
  border: 1px solid rgba(167,139,250,0.3);
  border-radius: 8px;
  padding: 5px 12px;
  font-size: 12px;
  color: var(--social);
  cursor: pointer;
  font-family: 'DM Sans', sans-serif;
  transition: background 0.15s;
}
.sponsor-add-btn:hover { background: rgba(167,139,250,0.25); }

.sponsor-empty {
  text-align: center;
  padding: 20px;
  color: var(--muted);
  font-size: 13px;
}

.sponsor-list { display: flex; flex-direction: column; gap: 10px; }
.sponsor-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 12px;
  background: var(--surface2);
  border-radius: 10px;
}
.sponsor-avatar {
  width: 36px; height: 36px;
  border-radius: 50%;
  background: var(--surface3);
  display: flex; align-items: center; justify-content: center;
  font-size: 14px;
  font-weight: 700;
  color: var(--social);
}
.sponsor-name { font-size: 13px; font-weight: 600; }
.sponsor-goal { font-size: 11px; color: var(--muted); }
.sponsor-incentive {
  margin-left: auto;
  font-size: 11px;
  color: var(--accent);
  background: rgba(200,169,126,0.1);
  padding: 3px 9px;
  border-radius: 20px;
}

/* ─── GOAL GENERATOR PANEL ────────────────────────────────── */
.panel-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  z-index: 100;
  backdrop-filter: blur(4px);
}
.panel-overlay.open { display: flex; align-items: center; justify-content: center; }

.panel {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 20px;
  width: 90%;
  max-width: 560px;
  max-height: 85vh;
  overflow-y: auto;
  padding: 28px;
  animation: slideUp 0.25s ease;
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22px;
}

.panel-title {
  font-family: 'Playfair Display', serif;
  font-size: 20px;
  font-weight: 700;
}

.panel-close {
  background: var(--surface3);
  border: none;
  border-radius: 8px;
  width: 32px; height: 32px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  color: var(--muted);
}
.panel-close:hover { color: var(--text); }
.panel-close svg { width: 16px; height: 16px; }

.form-group { margin-bottom: 16px; }
.form-label {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--muted);
  margin-bottom: 7px;
  display: block;
}

.form-input, .form-select, .form-textarea {
  width: 100%;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 11px 14px;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  color: var(--text);
  outline: none;
  transition: border-color 0.2s;
}
.form-input:focus, .form-select:focus, .form-textarea:focus {
  border-color: rgba(200,169,126,0.4);
}
