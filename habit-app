  ],
};

const affirmationMap = {
  'run': 'I am a runner', 'running': 'I am a runner',
  'yoga': 'I am flexible and present', 'gym': 'I am strong and disciplined',
  'sleep': 'I am someone who values deep rest', 'water': 'I am hydrated and clear',
  'meditat': 'I am at peace', 'journal': 'I am in tune with my inner world',
  'read': 'I am a lifelong learner', 'friend': 'I am a nurturer of deep bonds',
  'family': 'I am a devoted family member', 'walk': 'I am active and alive',
  'eat': 'I am someone who nourishes their body', 'diet': 'I am disciplined with my body',
  'pray': 'I am connected to something greater', 'gratitude': 'I am grateful and grounded',
  'stretch': 'I am flexible in body and mind',
};

// ─── INIT ─────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  setGreeting();
  setDate();
  renderHabits();
  renderFocusBars();
  renderTimeline();
  renderCalendar();
  updateStats();
});

function setGreeting() {
  const h = new Date().getHours();
  const g = h < 12 ? 'Good morning' : h < 17 ? 'Good afternoon' : 'Good evening';
  document.getElementById('greeting').textContent = g + ' ✦';
}

function setDate() {
  const now = new Date();
  const opts = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
  document.getElementById('today-date').textContent = now.toLocaleDateString('en-US', opts);
}

// ─── HABITS ───────────────────────────────
function renderHabits() {
  const list = document.getElementById('habits-list');
  const filtered = currentFilter === 'all' ? habits : habits.filter(h => h.cat === currentFilter);
  list.innerHTML = '';

  filtered.forEach(h => {
    const week = h.dots.map((d, i) => `<div class="habit-dot${d ? ' done' : ''}"></div>`).join('');
    list.innerHTML += `
    <div class="habit-card${h.done ? ' completed' : ''}${h.paused ? ' paused' : ''}" data-cat="${h.cat}" id="habit-${h.id}">
      <button class="complete-btn" onclick="toggleHabit(${h.id})">
        <svg class="circle-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="20" height="20"><circle cx="12" cy="12" r="10"/></svg>
        <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      </button>
      <div class="habit-info">
        <div class="habit-name">${h.name}</div>
        <div class="habit-affirmation">"${h.affirmation}"</div>
        <div class="habit-meta">
          <div class="habit-streak">🔥 ${h.streak} days</div>
          <div class="habit-freq">${h.freq}</div>
          ${h.paused ? '<div class="paused-badge">Paused</div>' : ''}
        </div>
      </div>
      <div class="habit-right">
        <div class="habit-dots">${week}</div>
        <div class="habit-actions">
          <button class="hab-action-btn" onclick="openPause(${h.id})" title="Pause">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </button>
          <button class="hab-action-btn" onclick="deleteHabit(${h.id})" title="Delete">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
          </button>
        </div>
      </div>
    </div>`;
  });

  if (filtered.length === 0) {
    list.innerHTML = `<div style="text-align:center; padding: 40px; color: var(--muted); font-size: 14px;">No habits in this category yet. <span style="color: var(--accent); cursor: pointer;" onclick="openPanel('goal-panel')">Add one ✦</span></div>`;
  }
  updateBadges();
}

function toggleHabit(id) {
  const h = habits.find(h => h.id === id);
  if (!h || h.paused) return;
  h.done = !h.done;
  if (h.done) {
    h.dots[6] = true;
    h.streak++;
    showToast(`✦ "${h.name}" — well done! You are becoming who you want to be.`);
  } else {
    h.dots[6] = false;
    h.streak = Math.max(0, h.streak - 1);
  }
  renderHabits();
  updateStats();
}

function deleteHabit(id) {
  habits = habits.filter(h => h.id !== id);
  renderHabits();
  updateStats();
  renderFocusBars();
  showToast('Habit removed.');
}

function updateStats() {
  const done = habits.filter(h => h.done).length;
  const total = habits.length;
  document.getElementById('stat-done').textContent = done;
  document.getElementById('stat-done-sub').textContent = `of ${total} goals`;
  document.getElementById('stat-total').textContent = total;
  const pct = total ? Math.round((done / total) * 100) : 0;
  document.getElementById('ring-completion').style.strokeDashoffset = 100 - pct;
  document.getElementById('ring-completion-val').textContent = pct + '%';
}

function filterCat(cat, el) {
  currentFilter = cat;
  document.querySelectorAll('.cat-item').forEach(i => i.classList.remove('active'));
  el.classList.add('active');
  renderHabits();
}

function updateBadges() {
  const cats = ['physical', 'biological', 'social', 'emotional', 'spiritual'];
  cats.forEach(c => {
    document.getElementById('badge-' + c).textContent = habits.filter(h => h.cat === c).length;
  });
  document.getElementById('badge-all').textContent = habits.length;
}

// ─── FOCUS BARS ───────────────────────────
function renderFocusBars() {
  const cats = [
    { key: 'physical', label: 'Physical', color: 'var(--physical)', emoji: '🏃' },
    { key: 'biological', label: 'Bio', color: 'var(--biological)', emoji: '🌿' },
    { key: 'social', label: 'Social', color: 'var(--social)', emoji: '🤝' },
    { key: 'emotional', label: 'Emotional', color: 'var(--emotional)', emoji: '💛' },
    { key: 'spiritual', label: 'Spiritual', color: 'var(--spiritual)', emoji: '✨' },
  ];
  const total = habits.length || 1;
  const makeBar = (c) => {
    const count = habits.filter(h => h.cat === c.key).length;
    const pct = Math.round((count / total) * 100);
    return `<div class="focus-bar-row">
      <div class="focus-bar-label">${c.emoji} ${c.label}</div>
      <div class="focus-bar-track"><div class="focus-bar-fill" style="width: ${pct}%; background: ${c.color};"></div></div>
      <div class="focus-bar-pct">${pct}%</div>
    </div>`;
  };
  const html = cats.map(makeBar).join('');
  const el1 = document.getElementById('focus-bars');
  const el2 = document.getElementById('focus-bars-full');
  if (el1) el1.innerHTML = html;
  if (el2) el2.innerHTML = html;
}

// ─── TIMELINE ─────────────────────────────
function renderTimeline() {
  const items = [
    { date: 'May 2026', title: 'Started Journaling', desc: 'Added daily emotional reflection habit.', done: false },
    { date: 'Apr 2026', title: '14-Day Running Streak', desc: 'Hit a record streak — "I am a runner."', done: true },
    { date: 'Mar 2026', title: 'Added Sleep Habit', desc: 'Committed to 8hrs after tracking fatigue.', done: true },
    { date: 'Feb 2026', title: 'First Sponsor Added', desc: 'Jamie joined as accountability partner.', done: true },
    { date: 'Jan 2026', title: 'Flourish Journey Begins', desc: 'Set first 3 goals. The path starts here.', done: true },
  ];
  const list = document.getElementById('timeline-list');
  list.innerHTML = items.map(i => `
    <div class="tl-item">
      <div class="tl-dot${i.done ? ' done' : ''}"></div>
      <div class="tl-date">${i.date}</div>
      <div class="tl-title">${i.title}</div>
      <div class="tl-desc">${i.desc}</div>
    </div>
  `).join('');
}

// ─── CALENDAR ─────────────────────────────
function renderCalendar() {
  const labels = ['Su', 'Mo', 'Tu', 'We', 'Th', 'Fr', 'Sa'];
  const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  document.getElementById('cal-month-label').textContent = `${months[calMonth]} ${calYear}`;

  const grid = document.getElementById('cal-grid');
  grid.innerHTML = labels.map(l => `<div class="cal-day-label">${l}</div>`).join('');

  const firstDay = new Date(calYear, calMonth, 1).getDay();
  const daysInMonth = new Date(calYear, calMonth + 1, 0).getDate();
  const today = new Date();

  // Perfect days simulation
  const perfectDays = new Set([3, 5, 8, 12, 14, 15, 19, 21]);
  const partialDays = new Set([1, 6, 9, 13, 17, 20, 22, 25]);

  for (let i = 0; i < firstDay; i++) {
    grid.innerHTML += `<div class="cal-day"></div>`;
  }
  for (let d = 1; d <= daysInMonth; d++) {
    const isToday = d === today.getDate() && calMonth === today.getMonth() && calYear === today.getFullYear();
    const isPerfect = perfectDays.has(d) && !isToday;
    const isPartial = partialDays.has(d) && !isToday;
    let cls = 'cal-day in-month';
    if (isToday) cls += ' today';
    else if (isPerfect) cls += ' perfect';
    else if (isPartial) cls += ' completed';
    grid.innerHTML += `<div class="${cls}">${d}</div>`;
  }
}

function changeMonth(dir) {
  calMonth += dir;
  if (calMonth > 11) { calMonth = 0; calYear++; }
  if (calMonth < 0) { calMonth = 11; calYear--; }
  renderCalendar();
}

// ─── PANELS ───────────────────────────────
function openPanel(id) {
  document.getElementById(id).classList.add('open');
  if (id === 'goal-panel') populateAiSuggestions();
}

function closePanel(id) {
  document.getElementById(id).classList.remove('open');
}

function closeIfOverlay(e, id) {
  if (e.target === document.getElementById(id)) closePanel(id);
}

function openPanelWithCat(cat) {
  selectedCat = cat;
  toggleAiPath(true);
  openPanel('goal-panel');
  const btn = document.querySelector(`.cat-sel-btn[data-cat="${cat}"]`);
  if (btn) selectCat(btn);
  switchView('home', document.querySelector('.sidebar-nav-btn'));
}

function openPause(id) {
  pauseTargetId = id;
  openPanel('pause-modal');
  const d = new Date();
  d.setDate(d.getDate() + 7);
  document.getElementById('resume-date').value = d.toISOString().split('T')[0];
}

// ─── GOAL CREATION ─────────────────────────
function toggleAiPath(useAi) {
  document.getElementById('ai-btn').classList.toggle('active', useAi);
  document.getElementById('own-btn').classList.toggle('active', !useAi);
  document.getElementById('ai-suggestions-section').style.display = useAi ? 'block' : 'none';
  document.getElementById('manual-form-section').style.display = useAi ? 'none' : 'block';
}

function populateAiSuggestions() {
  const list = document.getElementById('ai-suggestions-list');
  const cat = selectedCat || 'physical';
  const goals = aiGoals[cat] || aiGoals.physical;
  list.innerHTML = goals.map((g, i) => `
    <div class="ai-suggestion" onclick="selectAiGoal(${i}, '${cat}')">
      <div class="ai-suggestion-name">${g.name}</div>
      <div class="ai-suggestion-affirmation">"${g.affirmation}"</div>
    </div>
  `).join('');
  selectedAiGoal = null;
}

function selectAiGoal(i, cat) {
  const goals = aiGoals[cat] || aiGoals.physical;
  selectedAiGoal = { ...goals[i], cat };
  document.querySelectorAll('.ai-suggestion').forEach((el, idx) => {
    el.style.borderColor = idx === i ? 'rgba(200,169,126,0.5)' : '';
    el.style.background = idx === i ? 'rgba(200,169,126,0.08)' : '';
  });
}

function selectCat(btn) {
  document.querySelectorAll('.cat-sel-btn').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
  selectedCat = btn.dataset.cat;
  if (document.getElementById('ai-btn').classList.contains('active')) {
    populateAiSuggestions();
  }
}

function updateAffirmation() {
  const input = document.getElementById('goal-name-input').value.toLowerCase();
  const prev = document.getElementById('affirmation-preview');
  let found = '';
  for (const [key, val] of Object.entries(affirmationMap)) {
    if (input.includes(key)) { found = val; break; }
  }
  if (!found && input.length > 3) found = `I am someone who ${input}s with intention`;
  if (found) {
    prev.textContent = `✦ "${found}"`;
    prev.style.display = 'block';
  } else {
    prev.style.display = 'none';
  }
}

function createGoal() {
  const useAi = document.getElementById('ai-btn').classList.contains('active');
  let name, affirmation, cat, freq, reminder;

  if (useAi) {
    if (!selectedAiGoal) { showToast('Please select a goal suggestion.'); return; }
    name = selectedAiGoal.name;
    affirmation = selectedAiGoal.affirmation;
    cat = selectedAiGoal.cat;
    freq = selectedAiGoal.freq;
    reminder = selectedAiGoal.reminder;
  } else {
    name = document.getElementById('goal-name-input').value.trim();
    if (!name) { showToast('Please enter a goal name.'); return; }
    cat = selectedCat;
    if (!cat) { showToast('Please select a category.'); return; }
    const input = name.toLowerCase();
    affirmation = '';
    for (const [key, val] of Object.entries(affirmationMap)) {
      if (input.includes(key)) { affirmation = val; break; }
    }
    if (!affirmation) affirmation = `I am someone who ${name.toLowerCase()}s with intention`;
    freq = document.getElementById('goal-freq').value;
    reminder = document.getElementById('goal-reminder').value;
  }

  const newHabit = {
    id: Date.now(),
    name, affirmation, cat, freq, reminder,
    streak: 0,
    done: false,
    paused: false,
    dots: [false, false, false, false, false, false, false],
  };

  habits.push(newHabit);
  closePanel('goal-panel');
  renderHabits();
  renderFocusBars();
  updateStats();
  selectedAiGoal = null;
  selectedCat = '';
  document.getElementById('goal-name-input').value = '';
  document.getElementById('affirmation-preview').style.display = 'none';
  showToast(`✦ "${name}" added! ${affirmation}`);
}

// ─── CHECK-IN ─────────────────────────────
function selectMood(btn) {
  document.querySelectorAll('.mood-btn').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
}

function completeCheckin() {
  const mood = document.querySelector('.mood-btn.selected');
  if (!mood) { showToast('Pick a mood to check in.'); return; }
  closePanel('checkin-panel');
  document.getElementById('checkin-banner').style.display = 'none';
  showToast('✦ Check-in complete. Keep showing up — it adds up!');
}

// ─── PAUSE ─────────────────────────────────
function selectReason(btn) {
  document.querySelectorAll('.pause-reason-btn').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
}

function confirmPause() {
  const h = habits.find(h => h.id === pauseTargetId);
  if (h) { h.paused = !h.paused; }
  closePanel('pause-modal');
  renderHabits();
  showToast(h?.paused ? `"${h.name}" paused. It'll be here when you're back. ✦` : `"${h?.name}" resumed!`);
}

// ─── SPONSOR ──────────────────────────────
function addSponsor() {
  const name = prompt('Sponsor name:');
  if (!name) return;
  const incentive = prompt('What\'s at stake? (e.g. Coffee bet, $10 donation)') || 'Accountability';
  const goal = habits.length ? habits[0].name : 'Your goals';
  const list = document.getElementById('sponsor-list').querySelector('.sponsor-list');
  const initials = name.split(' ').map(w => w[0]).join('').toUpperCase().slice(0, 2);
  const div = document.createElement('div');
  div.className = 'sponsor-item';
  div.innerHTML = `
    <div class="sponsor-avatar">${initials}</div>
    <div>
      <div class="sponsor-name">${name}</div>
      <div class="sponsor-goal">Watching: ${goal}</div>
    </div>
    <div class="sponsor-incentive">🎯 ${incentive}</div>`;
  list.appendChild(div);
  showToast(`${name} is now your sponsor! ✦`);
}

// ─── VIEWS ────────────────────────────────
function switchView(view, btn) {
  currentView = view;
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.getElementById('view-' + view).classList.add('active');
  document.querySelectorAll('.sidebar-nav-btn').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
}

// ─── TOAST ────────────────────────────────
let toastTimer;
function showToast(msg, icon = '✦') {
  const t = document.getElementById('toast');
  document.getElementById('toast-msg').textContent = msg;
  document.getElementById('toast-icon').textContent = icon;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 3500);
}

// ─── SIMULATED NOTIFICATIONS ──────────────
setTimeout(() => {
  showToast('🔔 Reminder: "Morning Run" is due today!');
}, 2000);
</script>
